generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Almacenes {
  id          Int           @id @default(autoincrement())
  almacenID   String        @unique
  almacen     String
  ubicaciones Ubicaciones[]
}

model Arqueo {
  id                  Int      @id @default(autoincrement())
  arqueoID            String   @unique
  usuarioCodigo       Int
  fecha               DateTime @default(now())
  totalEfectivo       Decimal  @default(0)
  totalBac            Decimal  @default(0)
  totalFicohsa        Decimal  @default(0)
  totalDavivienda     Decimal  @default(0)
  totalTransferencias Decimal  @default(0)
  totalRetiros        Decimal  @default(0)
  totalDevoluciones   Decimal  @default(0)
  totalFacturado      Decimal  @default(0)
  usuario             Usuarios @relation(fields: [usuarioCodigo], references: [codigo])
}

model Categoria {
  id                   Int                    @id @default(autoincrement())
  categoriaID          String                 @unique
  nombre               String
  CategoriaProveedores CategoriaProveedores[]
  Productos            Productos[]
}

model Cierres {
  id                  Int      @id @default(autoincrement())
  cierreID            String   @unique
  usuarioCodigo       Int
  fecha               DateTime @default(now())
  totalEfectivo       Decimal
  totalBac            Decimal
  totalFicohsa        Decimal
  totalDavivienda     Decimal
  totalTransferencias Decimal
  totalRetiros        Decimal
  totalDevoluciones   Decimal
  totalFacturado      Decimal
  totalRecibido       Decimal
  diferencia          Decimal
  usuario             Usuarios @relation(fields: [usuarioCodigo], references: [codigo])
}

model Clientes {
  id           Int       @id @default(autoincrement())
  clienteID    String    @unique
  rtn          String    @unique
  nombre       String
  correo       String?
  telefono     String?
  departamento String?
  municipio    String?
  barrio       String?
  direccion    String?
  pedidos      Pedidos[]
  ventas       Ventas[]
}

model Devoluciones {
  id             Int       @id @default(autoincrement())
  devolucionID   String    @unique
  ventaId        Int
  productoCodigo String
  cantidad       Int
  motivo         String
  fecha          DateTime  @default(now())
  producto       Productos @relation(fields: [productoCodigo], references: [codigo])
  venta          Ventas    @relation(fields: [ventaId], references: [id])
}

model Inventario {
  id             Int         @id @default(autoincrement())
  productoCodigo String
  ubicacion      String      @unique
  cantidad       Int
  producto       Productos   @relation(fields: [productoCodigo], references: [codigo])
  ubicacionRel   Ubicaciones @relation(fields: [ubicacion], references: [ubicacion])
}

model Marca {
  id           Int         @id @default(autoincrement())
  marcaID      String      @unique
  nombre       String
  proveedorId  Int
  proveedorRel Proveedores @relation(fields: [proveedorId], references: [id])
  productos    Productos[]
}

model MovimientosInventario {
  id             Int       @id @default(autoincrement())
  productoCodigo String
  tipo           String
  cantidad       Int
  fecha          DateTime  @default(now())
  referencia     String?
  usuarioCodigo  Int
  producto       Productos @relation(fields: [productoCodigo], references: [codigo])
  usuario        Usuarios  @relation(fields: [usuarioCodigo], references: [codigo])
}

model Pedidos {
  id                 Int                  @id @default(autoincrement())
  pedidoID           String               @unique
  clienteID          Int
  usuarioCodigo      Int
  fecha              DateTime             @default(now())
  estado             String
  subtotal           Decimal
  impuesto           Decimal
  descuento          Decimal
  total              Decimal
  aprobado           Boolean              @default(false)
  detalles           PedidoDetalle[]
  cliente            Clientes             @relation(fields: [clienteID], references: [id])
  usuario            Usuarios             @relation(fields: [usuarioCodigo], references: [codigo])
  solicitudDescuento SolicitudDescuento[]
}

model PedidoDetalle {
  id                 Int                  @id @default(autoincrement())
  pedidoID           Int
  productoCodigo     String
  ubicacion          String
  cantidad           Int
  precioUnitario     Decimal
  subtotal           Decimal
  descuento          Decimal              @default(0)
  pedido             Pedidos              @relation(fields: [pedidoID], references: [id])
  producto           Productos            @relation(fields: [productoCodigo], references: [codigo])
  ubicacionRel       Ubicaciones          @relation(fields: [ubicacion], references: [ubicacion])
  solicitudDescuento SolicitudDescuento[]
}

model Perfil {
  id                 Int       @id @default(autoincrement())
  dni                String
  nombre             String
  telefono           String
  cargo              String
  departamento       String
  dir_departamento   String
  dir_municipio      String?
  dir_barrio         String?
  direccion          String
  fechaIngreso       DateTime
  fechaUltimoAscenso DateTime
  usuario            Usuarios?
}

model Productos {
  id                 Int                     @id @default(autoincrement())
  productoID         String                  @unique
  codigo             String                  @unique
  producto           String
  costoCompra        Decimal
  costoVenta         Decimal
  precio             Decimal
  descuento          Decimal
  descripcion        String
  categoriaId        Int
  proveedorId        Int
  marcaId            Int
  imagenUrl          String?
  devoluciones       Devoluciones[]
  inventario         Inventario[]
  movimientos        MovimientosInventario[]
  pedidoDetalles     PedidoDetalle[]
  categoriaRel       Categoria               @relation(fields: [categoriaId], references: [id])
  marcaRel           Marca                   @relation(fields: [marcaId], references: [id])
  proveedorRel       Proveedores             @relation(fields: [proveedorId], references: [id])
  solicitudDescuento SolicitudDescuento[]
  ventaDetalles      VentaDetalle[]
}

model Proveedores {
  id                   Int                    @id @default(autoincrement())
  proveedorID          String                 @unique
  rtn                  String                 @unique
  proveedor            String
  CategoriaProveedores CategoriaProveedores[]
  Marca                Marca[]
  productos            Productos[]
}

model SolicitudDescuento {
  id                   Int           @id @default(autoincrement())
  solicitudID          String        @unique
  pedidoDetalleId      Int
  pedidoId             Int
  productoCodigo       String
  vendedorCodigo       Int
  precioLista          Decimal
  costoVenta           Decimal
  porcentajeSolicitado Decimal
  descuentoSolicitado  Decimal
  precioFinal          Decimal
  nivelAprobacion      String
  estado               String        @default("PENDIENTE")
  motivo               String?
  fecha                DateTime      @default(now())
  aprobadoPorCodigo    Int?
  aprobadoPor          Usuarios?     @relation("Aprobaciones", fields: [aprobadoPorCodigo], references: [codigo])
  pedidoDetalle        PedidoDetalle @relation(fields: [pedidoDetalleId], references: [id])
  pedido               Pedidos       @relation(fields: [pedidoId], references: [id])
  producto             Productos     @relation(fields: [productoCodigo], references: [codigo])
  vendedor             Usuarios      @relation(fields: [vendedorCodigo], references: [codigo])
}

model Ubicaciones {
  ubicacion      String          @id
  deposito       Int
  estante        Int
  nivel          Int
  almacenId      Int
  inventario     Inventario?
  pedidoDetalles PedidoDetalle[]
  almacen        Almacenes       @relation(fields: [almacenId], references: [id])
}

model Usuarios {
  codigo                      Int                     @id @default(autoincrement())
  contrasena                  String
  rol                         String
  perfilId                    Int                     @unique
  arqueos                     Arqueo[]
  cierres                     Cierres[]
  movimientos                 MovimientosInventario[]
  pedidos                     Pedidos[]
  solicitudDescuentoAprobador SolicitudDescuento[]    @relation("Aprobaciones")
  solicitudDescuentoVendedor  SolicitudDescuento[]
  perfil                      Perfil                  @relation(fields: [perfilId], references: [id])
  ventas                      Ventas[]
}

model CategoriaProveedores {
  categoriaId Int
  proveedorId Int
  categoria   Categoria   @relation(fields: [categoriaId], references: [id])
  proveedor   Proveedores @relation(fields: [proveedorId], references: [id])

  @@id([categoriaId, proveedorId])
}

model Ventas {
  id            Int            @id @default(autoincrement())
  ventaID       String         @unique
  clienteID     Int
  fecha         DateTime       @default(now())
  estado        String
  tipoVenta     String
  subtotal      Decimal
  impuesto      Decimal
  descuento     Decimal
  total         Decimal
  metodoPago    String
  totalRecibido Decimal
  cambio        Decimal
  usuarioCodigo Int
  devoluciones  Devoluciones[]
  detalles      VentaDetalle[]
  cliente       Clientes       @relation(fields: [clienteID], references: [id])
  usuario       Usuarios       @relation(fields: [usuarioCodigo], references: [codigo])
}

model VentaDetalle {
  id             Int       @id @default(autoincrement())
  ventaID        Int
  productoCodigo String
  nombreProducto String
  cantidad       Int
  precioUnitario Decimal
  subtotal       Decimal
  descuento      Decimal
  producto       Productos @relation(fields: [productoCodigo], references: [codigo])
  venta          Ventas    @relation(fields: [ventaID], references: [id])
}
