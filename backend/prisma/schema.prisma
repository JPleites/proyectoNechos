generator client {
  provider     = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Clientes {
  id        String @id
  nombre    String
  correo    String @unique
  telefono  String @unique
  direccion String
}

model Productos {
  codigo       String       @id
  producto     String
  costo        Float
  precio       Float
  descuento    Int
  proveedor    String
  marca        String
  categoria    String
  descripcion  String
  inventario   Inventario[]
  proveedorRel Proveedores  @relation(fields: [proveedor], references: [rtn])
}

model Inventario {
  id               Int         @id @default(autoincrement())
  productoCodigo   String
  ubicacion        String
  ultimoMovimiento DateTime
  tipoMovimiento   String
  ultimoUsuario    String
  producto         Productos   @relation(fields: [productoCodigo], references: [codigo])
  ubicacionRel     Ubicaciones @relation(fields: [ubicacion], references: [ubicacion])
}

model Almacenes {
  id          String        @id
  almacen     String
  ubicaciones Ubicaciones[]
}

model Ubicaciones {
  ubicacion  String       @id
  estante    String
  nivel      String
  almacenId  String
  inventario Inventario[]
  almacen    Almacenes    @relation(fields: [almacenId], references: [id])
}

model Categoria {
  id                   String                 @id
  nombre               String
  CategoriaProveedores CategoriaProveedores[]
}

model Proveedores {
  rtn                  String                 @id
  proveedor            String
  CategoriaProveedores CategoriaProveedores[]
  productos            Productos[]
}

model CategoriaProveedores {
  categoriaId  String
  proveedorRtn String
  categoria    Categoria   @relation(fields: [categoriaId], references: [id])
  proveedor    Proveedores @relation(fields: [proveedorRtn], references: [rtn])

  @@id([categoriaId, proveedorRtn])
}

model Usuarios {
  codigo     Int     @id @default(autoincrement())
  contrasena String
  rol        String
  perfilId   Int     @unique
  perfil     Perfil  @relation(fields: [perfilId], references: [id])
}

model Perfil {
  id                 Int       @id @default(autoincrement())
  dni                String
  nombre             String
  telefono           String
  cargo              String
  departamento       String
  direccion          String
  fechaIngreso       DateTime
  fechaUltimoAscenso DateTime
  usuario            Usuarios?
}

model Arqueo {
  id                  Int      @id @default(autoincrement())
  usuarioCodigo       Int
  fecha               DateTime
  TotalEfectivo       Float
  totalBac            Float
  totalFicohsa        Float
  totalDavivienda     Float
  totalTransferencias Float
  totalRetiros        Float
  totalDevoluciones   Float
}

model Cierres {
  id                  Int      @id @default(autoincrement())
  usuarioCodigo       Int
  fecha               DateTime
  TotalEfectivo       Float
  totalBac            Float
  totalFicohsa        Float
  totalDavivienda     Float
  totalTransferencias Float
  totalRetiros        Float
  totalDevoluciones   Float
  totalFacturado      Float
  totalRecibido       Float
  diferencia          Float
}
